<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    <ul>
        <% projects.forEach(project => { %>
            <li>
                <strong><%= project.date.toDateString() %></strong>: 
                <%= project.title %> (<%= project.organization_name %>)
                <br>
                <em><%= project.location %></em> - <%= project.description %>
            </li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>



