<%- include('partials/header') %>

<main class="categories-page">
    <section class="categories-hero">
        <h1><%= title %></h1>
        <p>
            Explore different service project categories and discover
            opportunities to make a positive impact in communities around the world.
        </p>
    </section>

    <section class="categories-container">

        <article class="category-card">
            <h2>Environmental</h2>
            <p>
                Participate in projects focused on protecting the environment,
                conserving wildlife, recycling, and promoting sustainability.
            </p>
        </article>

        <article class="category-card">
            <h2>Educational</h2>
            <p>
                Support learning initiatives through tutoring, mentoring,
                literacy programs, and educational outreach services.
            </p>
        </article>

        <article class="category-card">
            <h2>Community Service</h2>
            <p>
                Help strengthen local communities through volunteer programs,
                food drives, housing assistance, and public improvement projects.
            </p>
        </article>

        <article class="category-card">
            <h2>Health and Wellness</h2>
            <p>
                Contribute to projects that promote physical health, mental wellness,
                healthcare awareness, and community support services.
            </p>
        </article>

    </section>
</main>

<%- include('partials/footer') %>